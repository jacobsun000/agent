{
  // This file is bootstrapped into ~/.agent/config.jsonc. Fill in your values.
  "agent": {
    "model": "openai/gpt-5.4"
  },
  "heartbeat": {
    "model": "openai/gpt-5-mini",
    "interval": "1800",
    "reportSession": "telegram:xxx"
  },
  "providers": [
    {
      "name": "openai",
      "apiKey": "sk-..."
    }
  ],
  "channels": {
    "http": {
      "enabled": true,
      "host": "127.0.0.1",
      "port": 8100,
      "url": "http://127.0.0.1:8100"
    },
    "telegram": {
      "enabled": true,
      "token": "123456:telegram-bot-token"
    }
  }
}
